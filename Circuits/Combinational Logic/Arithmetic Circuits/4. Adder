module top_module (
    input [3:0] x,
    input [3:0] y, 
    output [4:0] sum);
    
    wire [3:0]cout;
    wire cin;
    
    FA U0(x[0],y[0],cin,cout[0],sum[0]);
    FA U1(x[1],y[1],cout[0],cout[1],sum[1]);
    FA U3(x[2],y[2],cout[1],cout[2],sum[2]);
    FA U4(x[3],y[3],cout[2],cout[3],sum[3]);
    
    assign sum[4]=cout[3];
    
endmodule

module FA( 
    input a, b, cin,
    output cout, sum );
    
    assign sum=a^b^cin;
    assign cout=(a&b)|(a^b)&cin;

endmodule
