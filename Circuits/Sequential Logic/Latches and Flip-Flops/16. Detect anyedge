module top_module (
    input clk,
    input [7:0] in,
    output [7:0] anyedge
);
    reg [7:0] in_x=0;
    
    always@(posedge clk)begin
        for(integer i=0;i<8;i=i+1)begin
            if( (in_x[i]) != (in[i]) )
                anyedge[i] <= 1;
            else
                anyedge[i] <= 0;
        end
        in_x=in;
    end

endmodule
