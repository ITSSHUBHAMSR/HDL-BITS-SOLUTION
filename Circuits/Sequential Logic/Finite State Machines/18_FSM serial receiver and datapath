module top_module(
    input clk,
    input in,
    input reset,    // Synchronous reset
    output [7:0] out_byte,
    output done
); 
    parameter START=0, DATA=1, STOP=2, WAIT=3, DONE=4;
    reg [2:0] state, next_state;
    reg [3:0] count;
    reg [7:0] data;
    
    always@(*)begin
        state = next_state;
    end
    
    always@(posedge clk)begin
        if(reset)begin
                next_state <= START;
                count <= 0;
        end
        else begin
            case(state)
                START : begin next_state <= in?START:DATA; count <= 0; end
                DATA  : begin next_state <= (count<7)?DATA:STOP; count <= count+1; data[count] <= in; end
                STOP  : next_state <= in?DONE:WAIT;
                WAIT  : next_state <= in?START:WAIT;
                DONE  : begin next_state <= in?START:DATA; count <= 0; end
                default : next_state <= START;
            endcase
        end
    end
    
    assign done = (state == DONE);
    assign out_byte = data;

endmodule
