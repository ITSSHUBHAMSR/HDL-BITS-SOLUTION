module top_module (
    input clk,
    input areset,
    input x,
    output z
); 
    parameter S0=0, S1=1;
    reg state, next_state;
    
    always@(*)begin
        state = next_state;
    end
    
    always@(posedge clk or posedge areset)begin
        if(areset)begin
            next_state <= S0;
        end
        else begin
            case(state)
                S0 : next_state <= x?S1:S0;
                S1 : next_state <= S1; 
            endcase
        end
    end
    
    always@(*)begin
        case(state)
            S0 : z=x;
            S1: z=~x;
        endcase
    end
   
     

endmodule
