module top_module (
    input clk,
    input [2:0] y,
    input x,
    output Y0,
    output z
);
    parameter a = 0, b = 1, c = 2, d = 3, e = 4;
    reg [2:0] state;

    always @(*) 
        begin
            case (y)
            a: state = x ? b : a;
            b: state = x ? e : b;
            c: state = x ? b : c;
            d: state = x ? c : b;
            e: state = x ? e : d;
        endcase
    end

    assign z = (y == d) || (y == e);
    assign Y0=state[0];


endmodule
