module top_module(
	input clk, 
	input load, 
	input [9:0] data, 
	output tc
);
    reg [9:0] counter;
    
    always@(posedge clk)begin
        if(load) counter <= data;
        else begin
            if(counter == 'd0) counter <= 'd0;
            else counter <= counter-1;
        end
    end
    
    assign tc=(counter=='d0);

endmodule
