module top_module(
    input [31:0] a,
    input [31:0] b,
    input sub,
    output [31:0] sum
);
    
    wire c0,c1;
    wire [31:0] b_sub;
    
    assign b_sub = b^{32{sub}};
    
    add16 U0(
        .a(a[15:0]),
        .b(b_sub[15:0]),
        .cin(sub),
        .sum(sum[15:0]),
        .cout(c0)
    );

    add16 U1(
        .a(a[31:16]),
        .b(b_sub[31:16]),
        .cin(c0),
        .sum(sum[31:16]),
        .cout(c1)
    );
    

endmodule
